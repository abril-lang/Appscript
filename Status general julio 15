// Tabs de la spreadsheet — añade o quita según necesites
// Mitshell: ["TCC", "RISE", "NLA", "BTB", "OPY", "RL"]
// Veronica: ["LVL", "FE", "KAN", "CBM", "OZA", "SET", "BSS"]
const SHEET_TABS = ["REEMPLAZAR_CON_TUS_TABS"];

// Columnas (índice base 1)
const COL_LINK   = 4;  // D — Hipervínculo al ticket de ClickUp
const COL_STATUS = 8;  // H — Status (dropdown)
const COL_DATE   = 10; // J — Fecha (se llena cuando status = SENT)

// Etiqueta especial que cambia el status a RE-SIZES
const TAG_RESIZES = "add exports";

// Zona horaria para la fecha de SENT
const TIMEZONE = "America/Bogota";


// ============================================================
//  PART 1 — WEBHOOK
//  Recibe eventos de ClickUp en tiempo real
// ============================================================

function doPost(e) {
  try {
    const payload   = JSON.parse(e.postData.contents);
    const eventType = payload.event;
    const taskId    = payload.task_id;

    Logger.log("Webhook recibido — event: " + eventType + " | taskId: " + taskId);

    if (!taskId) return jsonResponse({ ok: false, reason: "no task_id" });
    if (!["taskStatusUpdated", "taskTagUpdated"].includes(eventType)) {
      return jsonResponse({ ok: true, reason: "evento ignorado" });
    }

    PropertiesService.getScriptProperties().setProperty("PENDING_TASK_" + taskId, eventType);
    ScriptApp.newTrigger("processPendingTask")
      .timeBased()
      .after(1000)
      .create();

    return jsonResponse({ ok: true, received: true });

  } catch (err) {
    Logger.log("Error en doPost: " + err);
    return jsonResponse({ ok: false, error: err.toString() });
  }
}

function processPendingTask() {
  const triggers = ScriptApp.getProjectTriggers();
  for (const t of triggers) {
    if (t.getHandlerFunction() === "processPendingTask") {
      ScriptApp.deleteTrigger(t);
    }
  }

  const props = PropertiesService.getScriptProperties().getProperties();
  for (const key of Object.keys(props)) {
    if (!key.startsWith("PENDING_TASK_")) continue;
    const taskId = key.replace("PENDING_TASK_", "");
    PropertiesService.getScriptProperties().deleteProperty(key);

    const taskData = getClickUpTaskWebhook(taskId);
    if (!taskData) continue;

    let newStatus = mapStatus(taskData.status?.status);
    const tags = taskData.tags || [];
    const hasResizeTag = tags.some(tag => tag.name?.toLowerCase() === TAG_RESIZES.toLowerCase());
    if (hasResizeTag && newStatus === "WORKING") newStatus = "RE-SIZES";
    if (!newStatus) continue;

    updateSheetRow(taskId, newStatus);
    Logger.log("Procesado: " + taskId + " -> " + newStatus);
  }
}

function updateSheetRow(taskId, newStatus) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  for (const tabName of SHEET_TABS) {
    const sheet = ss.getSheetByName(tabName);
    if (!sheet) continue;

    const lastRow = sheet.getLastRow();
    if (lastRow < 2) continue;

    const richValues = sheet.getRange(2, COL_LINK, lastRow - 1, 1).getRichTextValues();

    for (let i = 0; i < richValues.length; i++) {
      const url = extractUrl(richValues[i][0]);
      if (!url) continue;

      const cellTaskId = extractTaskId(url);
      if (cellTaskId !== taskId) continue;

      const row        = i + 2;
      const statusCell = sheet.getRange(row, COL_STATUS);
      const currentStatus = statusCell.getValue();

      if (currentStatus !== newStatus) {
        statusCell.setValue(newStatus);
        Logger.log("[" + tabName + "] Row " + row + ": " + currentStatus + " → " + newStatus);

        if (newStatus === "SENT") {
          const now = Utilities.formatDate(new Date(), TIMEZONE, "dd/MM/yyyy");
          sheet.getRange(row, COL_DATE).setValue(now);
          Logger.log("[" + tabName + "] SENT date → " + now);
        }
      }
      return;
    }
  }
  Logger.log("Tarea no encontrada en ninguna tab: " + taskId);
}

function getClickUpTaskWebhook(taskId) {
  try {
    const response = UrlFetchApp.fetch(
      "https://api.clickup.com/api/v2/task/" + taskId + "?include_subtasks=false",
      {
        method: "GET",
        headers: { Authorization: CLICKUP_API_KEY },
        muteHttpExceptions: true,
      }
    );
    if (response.getResponseCode() !== 200) return null;
    return JSON.parse(response.getContentText());
  } catch (e) {
    Logger.log("Error ClickUp API: " + e);
    return null;
  }
}

function borrarYReregistrar() {
  // ⚠️ IMPORTANTE: Reemplaza esta URL con la tuya después de hacer Deploy
  // Deploy → New Deployment → Web App → copiar URL /exec → pegar aquí
  const urlCorrecta = "PEGAR_TU_URL_EXEC_AQUI";

  const res = UrlFetchApp.fetch(
    "https://api.clickup.com/api/v2/team/" + CLICKUP_TEAM_ID + "/webhook",
    { headers: { Authorization: CLICKUP_API_KEY }, muteHttpExceptions: true }
  );
  const data = JSON.parse(res.getContentText());
  Logger.log("Webhooks existentes: " + JSON.stringify(data.webhooks));

  for (const wh of (data.webhooks || [])) {
    UrlFetchApp.fetch("https://api.clickup.com/api/v2/webhook/" + wh.id, {
      method: "DELETE",
      headers: { Authorization: CLICKUP_API_KEY },
      muteHttpExceptions: true,
    });
    Logger.log("Borrado: " + wh.id + " → " + wh.endpoint);
  }

  const response = UrlFetchApp.fetch(
    "https://api.clickup.com/api/v2/team/" + CLICKUP_TEAM_ID + "/webhook",
    {
      method: "POST",
      headers: { Authorization: CLICKUP_API_KEY, "Content-Type": "application/json" },
      payload: JSON.stringify({
        endpoint: urlCorrecta,
        events: ["taskStatusUpdated", "taskTagUpdated"],
        list_id: CLICKUP_LIST_ID,
      }),
      muteHttpExceptions: true,
    }
  );
  Logger.log("Registro nuevo HTTP: " + response.getResponseCode());
  Logger.log("Registro nuevo RAW: " + response.getContentText());
}

function jsonResponse(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}


// ============================================================
//  PART 2 — POLLING (respaldo cada 5 minutos)
//  Corre aunque el webhook falle
// ============================================================

function registrarTrigger() {
  const triggers = ScriptApp.getProjectTriggers();
  for (const t of triggers) {
    if (t.getHandlerFunction() === "syncStatuses") {
      ScriptApp.deleteTrigger(t);
    }
  }
  ScriptApp.newTrigger("syncStatuses")
    .timeBased()
    .everyMinutes(5)
    .create();
  Logger.log("✅ Trigger registrado — syncStatuses cada 5 minutos.");
}

function syncStatuses() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const taskMap = {};

  for (const tabName of SHEET_TABS) {
    const sheet = ss.getSheetByName(tabName);
    if (!sheet) continue;

    const lastRow = sheet.getLastRow();
    if (lastRow < 2) continue;

    const richValues   = sheet.getRange(2, COL_LINK, lastRow - 1, 1).getRichTextValues();
    const statusValues = sheet.getRange(2, COL_STATUS, lastRow - 1, 1).getValues();

    for (let i = 0; i < richValues.length; i++) {
      const url = extractUrl(richValues[i][0]);
      if (!url) continue;
      const taskId = extractTaskId(url);
      if (!taskId) continue;
      taskMap[taskId] = { tabName, row: i + 2, currentStatus: statusValues[i][0] || "" };
    }
  }

  const totalTasks = Object.keys(taskMap).length;
  if (totalTasks === 0) { Logger.log("No tasks found in any tab."); return; }
  Logger.log("Tasks found in spreadsheet: " + totalTasks);

  const cuStatusMap = fetchAllTaskStatuses();
  if (!cuStatusMap) { Logger.log("ERROR: Could not fetch tasks from ClickUp."); return; }
  Logger.log("Tasks fetched from ClickUp: " + Object.keys(cuStatusMap).length);

  let updatedCount = 0;

  for (const [taskId, sheetData] of Object.entries(taskMap)) {
    const cuData = cuStatusMap[taskId];
    if (!cuData) continue;

    let newStatus = mapStatus(cuData.status);
    const hasResizeTag = cuData.tags.some(tag =>
      tag.name?.toLowerCase() === TAG_RESIZES.toLowerCase()
    );
    if (hasResizeTag && newStatus === "WORKING") newStatus = "RE-SIZES";
    if (!newStatus) continue;
    if (newStatus === sheetData.currentStatus) continue;

    const sheet = ss.getSheetByName(sheetData.tabName);
    if (!sheet) continue;

    sheet.getRange(sheetData.row, COL_STATUS).setValue(newStatus);
    Logger.log("[" + sheetData.tabName + "] Row " + sheetData.row + ": " + sheetData.currentStatus + " → " + newStatus);

    if (newStatus === "SENT") {
      const now = Utilities.formatDate(new Date(), TIMEZONE, "dd/MM/yyyy");
      sheet.getRange(sheetData.row, COL_DATE).setValue(now);
      Logger.log("[" + sheetData.tabName + "] SENT date → " + now);
    }

    updatedCount++;
  }

  Logger.log("Sync complete — updated: " + updatedCount + " / " + totalTasks + " tasks checked.");
}

function fetchAllTaskStatuses() {
  const cuMap = {};
  let page = 0;
  const maxPages = 500;

  while (page < maxPages) {
    const url = "https://api.clickup.com/api/v2/list/" + CLICKUP_LIST_ID +
      "/task?page=" + page + "&include_subtasks=false&subtasks=false";

    try {
      const response = UrlFetchApp.fetch(url, {
        method: "GET",
        headers: { Authorization: CLICKUP_API_KEY },
        muteHttpExceptions: true,
      });

      if (response.getResponseCode() !== 200) {
        Logger.log("CU API error on page " + page + ": HTTP " + response.getResponseCode());
        break;
      }

      const data  = JSON.parse(response.getContentText());
      const tasks = data.tasks || [];

      for (const task of tasks) {
        cuMap[task.id] = { status: task.status?.status || "", tags: task.tags || [] };
      }

      if (tasks.length < 100) break;
      page++;
      Utilities.sleep(200);

    } catch (e) {
      Logger.log("Error fetching page " + page + ": " + e);
      break;
    }
  }

  return cuMap;
}


// ============================================================
//  HELPERS
// ============================================================

function extractUrl(richTextCell) {
  try {
    const runs = richTextCell.getRuns();
    for (const run of runs) {
      const link = run.getLinkUrl();
      if (link) return link;
    }
    const plainText = richTextCell.getText();
    if (plainText && plainText.startsWith("http")) return plainText;
  } catch (e) {}
  return null;
}

function extractTaskId(url) {
  try {
    const cleanUrl = url.split("?")[0];
    const longMatch = cleanUrl.match(/clickup\.com\/t\/\d+\/([a-zA-Z0-9]+)/);
    if (longMatch) return longMatch[1];
    const shortMatch = cleanUrl.match(/clickup\.com\/t\/([a-zA-Z0-9]+)/);
    if (shortMatch) return shortMatch[1];
    const segments = cleanUrl.split("/").filter(Boolean);
    return segments[segments.length - 1];
  } catch (e) {}
  return null;
}

function mapStatus(rawStatus) {
  if (!rawStatus) return null;
  const map = {
    "submitted":       "SUBMITTED",
    "on hold":         "ON HOLD",
    "working":         "WORKING",
    "quality control": "QUALITY CONTROL",
    "qc approved":     "QC APPROVED",
    "sent":            "SENT",
    "completadas":     "COMPLETADAS",
    "complete":        "COMPLETE",
    "cancelled":       "CANCELLED",
    "subtitling":      "SUBTITLING",
    "re-sizes":        "RE-SIZES",
  };
  return map[rawStatus.toLowerCase()] || rawStatus.toUpperCase();
}
