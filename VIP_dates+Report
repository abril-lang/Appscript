// ============================================================
// VIP QUEUE REPORT GENERATOR v2
// - Intro message in a single cell
// - Only shows versions with ACTIVE status (SUBMITTED/WORKING/QC APPROVED)
// - Skips versions already SENT or COMPLETE
// Add this to your existing .gs file (do not replace existing code)
// ============================================================

// Add this item to your onOpen menu manually:
// .addItem('📋 Generate VIP Report', 'generateVIPReport')

const REPORT_SHEET_NAME = 'VIP Report';
const ACTIVE_STATUSES   = ['SUBMITTED', 'WORKING', 'QC APPROVED', 'QC'];
const REPORT_FIRST_ROW  = 163;

  const INTRO_MESSAGE =
  "Here's what the queue looks like at the moment, based on show dates and taking into account " +
  "our observed holidays. You can check our observed holidays here:\nhttps://www.editcrew.com/observed-holidays";

// ------------------------------------------------------------
// CLEAN PROJECT NAME — removes "VIP#_" prefix
// e.g. "VIP204_20260709_RENEGADE" → "20260709_RENEGADE"
// ------------------------------------------------------------
function cleanProjectName(rawName) {
  if (!rawName) return '';
  return String(rawName).replace(/^VIP\d+_/i, '').trim();
}


// ------------------------------------------------------------
// CHECK IF ROW SHOULD BE INCLUDED IN REPORT
// Only includes row if at least one VERSION status is active
// (ignores main task status — what matters is pending subtasks)
// ------------------------------------------------------------
function isActiveRow(sheet, row) {
  let col = VERSION_COL_START;
  const lastCol = sheet.getLastColumn();
  while (col <= lastCol) {
    const versionLabel = String(sheet.getRange(row, col).getValue()).trim();
    if (!versionLabel) { col += COLS_PER_VERSION; continue; }
    const vStatus = String(sheet.getRange(row, col + STATUS_OFFSET).getValue()).trim().toUpperCase();
    if (ACTIVE_STATUSES.includes(vStatus)) return true;
    col += COLS_PER_VERSION;
  }
  return false;
}


// ------------------------------------------------------------
// BUILD VERSION LINES — only versions with ACTIVE status
// Groups versions that share the same due date
// e.g. V2 and V3 both June 2 → "• V2-V3 due: June 2"
// ------------------------------------------------------------
function buildVersionLines(sheet, row) {
  const dateGroups = {}; // date → [labels]
  const dateOrder  = []; // preserve insertion order

  let col = VERSION_COL_START;
  const lastCol = sheet.getLastColumn();

  while (col <= lastCol) {
    const versionCell = String(sheet.getRange(row, col).getValue()).trim();
    if (!versionCell) { col += COLS_PER_VERSION; continue; }

    // Only include versions with active status
    const vStatus = String(sheet.getRange(row, col + STATUS_OFFSET).getValue()).trim().toUpperCase();
    if (!ACTIVE_STATUSES.includes(vStatus)) { col += COLS_PER_VERSION; continue; }

    const label = normalizeCellLabel(versionCell) || versionCell;

    // Get due date
    const dueDateRaw = sheet.getRange(row, col + DUE_DATE_OFFSET).getValue();
    let dueDateStr = '';
    if (dueDateRaw instanceof Date) {
      dueDateStr = Utilities.formatDate(dueDateRaw, 'UTC', 'MMMM d');
    } else if (dueDateRaw) {
      dueDateStr = String(dueDateRaw).trim();
    }

    if (!dueDateStr) { col += COLS_PER_VERSION; continue; }

    if (!dateGroups[dueDateStr]) {
      dateGroups[dueDateStr] = [];
      dateOrder.push(dueDateStr);
    }
    dateGroups[dueDateStr].push(label);

    col += COLS_PER_VERSION;
  }

  // Build lines
  const lines = [];
  for (const date of dateOrder) {
    const labelStr = mergeConsecutiveLabels(dateGroups[date]);
    lines.push(`  • ${labelStr} due: ${date}`);
  }
  return lines;
}


// ------------------------------------------------------------
// MERGE CONSECUTIVE VERSION LABELS
// ["V1"] → "V1" | ["V2","V3"] → "V2-V3" | ["V1","V3"] → "V1, V3"
// ------------------------------------------------------------
function mergeConsecutiveLabels(labels) {
  if (!labels || labels.length === 0) return '';
  if (labels.length === 1) return labels[0];

  const allVersioned = labels.every(l => /^V\d+$/i.test(l));
  if (!allVersioned) return labels.join(', ');

  const nums = labels.map(l => parseInt(l.replace(/V/i, '')));
  let isConsecutive = true;
  for (let i = 1; i < nums.length; i++) {
    if (nums[i] !== nums[i - 1] + 1) { isConsecutive = false; break; }
  }

  return isConsecutive
    ? `V${nums[0]}-V${nums[nums.length - 1]}`
    : labels.join(', ');
}


// ------------------------------------------------------------
// MAIN REPORT GENERATOR
// ------------------------------------------------------------
function generateVIPReport() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const vipSheet = ss.getSheetByName('VIP');
  if (!vipSheet) {
    SpreadsheetApp.getUi().alert('⚠️ Tab "VIP" not found.');
    return;
  }

  const lastRow = vipSheet.getLastRow();

  // Collect report data: [ { name, lines[] } ]
  const projects = [];

  for (let row = REPORT_FIRST_ROW; row <= lastRow; row++) {

    // Skip rows without a CU link
    const cellVal  = vipSheet.getRange(row, COLUMN_CU_LINK).getValue();
    const richText = vipSheet.getRange(row, COLUMN_CU_LINK).getRichTextValue();
    let hasCuLink  = false;
    if (richText) {
      for (const run of richText.getRuns()) {
        if (run.getLinkUrl() && run.getLinkUrl().includes('clickup.com')) { hasCuLink = true; break; }
      }
    }
    if (!hasCuLink && (!cellVal || !String(cellVal).includes('clickup.com'))) continue;

    // Skip rows with no active version statuses
    if (!isActiveRow(vipSheet, row)) continue;

    // Get project name
    const richTextD = vipSheet.getRange(row, COLUMN_CU_LINK).getRichTextValue();
    let rawName = richTextD ? richTextD.getText() : String(cellVal);
    const cleanName = cleanProjectName(rawName);

    // Build version lines (only active versions)
    const versionLines = buildVersionLines(vipSheet, row);
    if (versionLines.length === 0) continue;

    projects.push({ name: cleanName, lines: versionLines });
  }

  if (projects.length === 0) {
    SpreadsheetApp.getUi().alert('⚠️ No active projects found (SUBMITTED, WORKING, or QC APPROVED).');
    return;
  }

  // Write to VIP Report tab (create if doesn't exist)
  let reportSheet = ss.getSheetByName(REPORT_SHEET_NAME);
  if (!reportSheet) {
    reportSheet = ss.insertSheet(REPORT_SHEET_NAME);
  } else {
    reportSheet.clearContents();
  }

// Todo el reporte en UNA SOLA celda
  let fullReport = INTRO_MESSAGE + '\n\n';

  for (const project of projects) {
    fullReport += project.name + '\n';
    for (const line of project.lines) {
      fullReport += line + '\n';
    }
    fullReport += '\n';
  }

  // Escribir en A1 — una sola celda
  reportSheet.getRange(1, 1).setValue(fullReport.trim());
  reportSheet.getRange(1, 1).setWrap(true);
  reportSheet.setColumnWidth(1, 600);

  // Autofit row height para que se vea todo
  reportSheet.setRowHeight(1, 40 * (fullReport.split('\n').length));

  // Activar la tab del reporte
  ss.setActiveSheet(reportSheet);

  SpreadsheetApp.getUi().alert(`✅ Report generated!\n\n${projects.length} active projects included.\n\nCheck the "VIP Report" tab.`);
}
