// ============================================================
// CLICKUP → SPREADSHEET SYNC — VIP  (v2)
// Syncs subtask due dates + status from ClickUp to Google Sheet
// Also syncs main task status to column H
// NEW: auto-appends extra subtasks (non-V1/V2/V3) to empty columns
// ============================================================

const COLUMN_CU_LINK     = 4;   // Column D — ClickUp main task hyperlink
const COLUMN_MAIN_STATUS = 8;   // Column H — main task status
const FIRST_DATA_ROW     = 6;   // Start from row 6 (active projects)
const VERSION_COL_START  = 9;   // Column I — first Version column (1-indexed)
const COLS_PER_VERSION   = 3;   // I=Version, J=Due Date, K=Status | L=Version...
const DUE_DATE_OFFSET    = 1;   // Due Date is 1 col after Version
const STATUS_OFFSET      = 2;   // Status is 2 cols after Version


// ------------------------------------------------------------
// MENU
// ------------------------------------------------------------
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('VIP Sync')
    .addItem('🔄 Sync ClickUp (Dates + Status)', 'syncClickUp')
    .addItem('📋 Generate VIP Report', 'generateVIPReport')
    .addItem('🔑 Set API Token', 'setApiToken')
    .addToUi();
}


// ------------------------------------------------------------
// SET API TOKEN
// ------------------------------------------------------------
function setApiToken() {
  const ui = SpreadsheetApp.getUi();
  const result = ui.prompt(
    'ClickUp API Token',
    'Paste your ClickUp API token (it will be stored securely):',
    ui.ButtonSet.OK_CANCEL
  );
  if (result.getSelectedButton() === ui.Button.OK) {
    const token = result.getResponseText().trim();
    if (token) {
      PropertiesService.getUserProperties().setProperty('CU_API_TOKEN', token);
      ui.alert('✅ Token saved successfully!');
    }
  }
}


// ------------------------------------------------------------
// GET API TOKEN
// ------------------------------------------------------------
function getApiToken() {
  const token = PropertiesService.getUserProperties().getProperty('CU_API_TOKEN');
  if (!token) {
    SpreadsheetApp.getUi().alert(
      '⚠️ No API token found.\n\nGo to VIP Sync → Set API Token first.'
    );
    return null;
  }
  return token;
}


// ------------------------------------------------------------
// EXTRACT TASK ID FROM CLICKUP URL
// ------------------------------------------------------------
function extractTaskId(url) {
  if (!url) return null;
  const match = url.match(/clickup\.com\/t\/([a-zA-Z0-9]+)/);
  return match ? match[1] : null;
}


// ------------------------------------------------------------
// FORMAT TIMESTAMP → "July 7" style
// ClickUp returns due dates in milliseconds
// ------------------------------------------------------------
function formatDueDate(timestampMs) {
  if (!timestampMs) return '';
  const date = new Date(parseInt(timestampMs));
  return Utilities.formatDate(date, 'UTC', 'MMMM d');
}


// ------------------------------------------------------------
// FETCH MAIN TASK + SUBTASKS FROM CLICKUP API
// ------------------------------------------------------------
function getTaskData(taskId, token) {
  const url = `https://api.clickup.com/api/v2/task/${taskId}?include_subtasks=true&subtasks=true`;

  const options = {
    method: 'GET',
    headers: {
      'Authorization': token,
      'Content-Type': 'application/json'
    },
    muteHttpExceptions: true
  };

  for (let attempt = 1; attempt <= 2; attempt++) {
    try {
      const response = UrlFetchApp.fetch(url, options);
      const code = response.getResponseCode();
      if (code === 200) return JSON.parse(response.getContentText());
      Logger.log(`Attempt ${attempt} — Error fetching task ${taskId}: HTTP ${code}`);
    } catch (e) {
      Logger.log(`Attempt ${attempt} — Connection error for task ${taskId}: ${e.message}`);
    }
    if (attempt === 1) Utilities.sleep(1000);
  }

  Logger.log(`Skipping task ${taskId} after 2 failed attempts`);
  return null;
}


// ------------------------------------------------------------
// PARSE VERSION LABEL FROM SUBTASK NAME
//
// FIX v2: Much more flexible matching.
// Handles: VIP210_V1, VIP210_V1 ABC, VIP210_V1ABC,
//          VIP179_Masters, VIP_Masters ABC, VIP210_Shoutout, etc.
// Returns normalized label: "V1", "V2", "Masters", "Shoutout", etc.
// ------------------------------------------------------------
function parseVersionLabel(name) {
  if (!name) return null;

  // Match _V followed by digits (with or without space/text after)
  const vMatch = name.match(/_V(\d+)/i);
  if (vMatch) return `V${vMatch[1]}`;

  // Match known extras (case-insensitive, after underscore or anywhere)
  const extras = ['Masters', 'Shoutout', 'Lyric', 'Lyrics', 'Square', 'Vertical', 'Horizontal'];
  for (const extra of extras) {
    if (name.match(new RegExp(extra, 'i'))) return extra.charAt(0).toUpperCase() + extra.slice(1).toLowerCase();
  }

  return null;
}


// ------------------------------------------------------------
// NORMALIZE LABEL for lookup (match sheet cell to CU label)
// Sheet cell may say "V1 ABC", "V1ABC", "Masters ABC", etc.
// Returns canonical label: "V1", "Masters", "Shoutout", etc.
// ------------------------------------------------------------
function normalizeCellLabel(cellText) {
  if (!cellText) return null;
  const text = String(cellText).trim();

  // Match V followed by digits at start (e.g. "V1 ABC", "V1ABC", "V1")
  const vMatch = text.match(/^V(\d+)/i);
  if (vMatch) return `V${vMatch[1]}`;

  // Match known extras at start
  const extras = ['Masters', 'Shoutout', 'Lyric', 'Lyrics', 'Square', 'Vertical', 'Horizontal'];
  for (const extra of extras) {
    if (text.match(new RegExp(`^${extra}`, 'i'))) {
      return extra.charAt(0).toUpperCase() + extra.slice(1).toLowerCase();
    }
  }

  return null;
}


// ------------------------------------------------------------
// NORMALIZE STATUS from CU
// ------------------------------------------------------------
function normalizeStatus(statusName) {
  if (!statusName) return '';
  return statusName.toUpperCase();
}


// ------------------------------------------------------------
// MAIN SYNC FUNCTION
// ------------------------------------------------------------
function syncClickUp() {
  const token = getApiToken();
  if (!token) return;

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('VIP');
  if (!sheet) {
    SpreadsheetApp.getUi().alert('⚠️ Tab "VIP" not found.');
    return;
  }

  const lastRow = sheet.getLastRow();
  const ui = SpreadsheetApp.getUi();

  let updatedRows = 0;
  let errorRows = 0;
  const skippedRows = [];

  for (let row = FIRST_DATA_ROW; row <= lastRow; row++) {

    // --- Get CU hyperlink from column D ---
    const cell = sheet.getRange(row, COLUMN_CU_LINK);
    const richText = cell.getRichTextValue();
    let cuUrl = null;

    if (richText) {
      const runs = richText.getRuns();
      for (const run of runs) {
        const link = run.getLinkUrl();
        if (link && link.includes('clickup.com')) {
          cuUrl = link;
          break;
        }
      }
    }

    // Fallback: plain cell value
    if (!cuUrl) {
      const val = cell.getValue();
      if (val && String(val).includes('clickup.com')) cuUrl = String(val);
    }

    if (!cuUrl) continue;

    const taskId = extractTaskId(cuUrl);
    if (!taskId) continue;

    // --- Fetch task data from CU ---
    const taskData = getTaskData(taskId, token);
    if (!taskData) {
      errorRows++;
      skippedRows.push(row);
      continue;
    }

    // --- Sync main task status → Column H ---
    const mainStatus = normalizeStatus(taskData.status?.status);
    if (mainStatus) {
      sheet.getRange(row, COLUMN_MAIN_STATUS).setValue(mainStatus);
    }

    // --- Build maps: normalizedLabel → { due_date, status } ---
    const subtasks = taskData.subtasks || [];
    const dueDateMap = {};
    const statusMap = {};

    for (const subtask of subtasks) {
      const label = parseVersionLabel(subtask.name);
      if (!label) {
        Logger.log(`Row ${row}: Could not parse label from subtask name: "${subtask.name}"`);
        continue;
      }
      if (subtask.due_date) dueDateMap[label] = formatDueDate(subtask.due_date);
      if (subtask.status?.status) statusMap[label] = normalizeStatus(subtask.status.status);
      Logger.log(`Row ${row}: CU subtask parsed → label="${label}", due="${dueDateMap[label] || ''}", status="${statusMap[label] || ''}"`);
    }

    // --- Scan existing version columns (I onwards) and update ---
    const lastCol = sheet.getLastColumn();
    let col = VERSION_COL_START;
    const coveredLabels = new Set(); // track which labels already exist in sheet
    let updated = false;

    while (col <= lastCol) {
      const cellVal = sheet.getRange(row, col).getValue();
      const versionText = String(cellVal).trim();

      if (!versionText) {
        col += COLS_PER_VERSION;
        continue;
      }

      const cellLabel = normalizeCellLabel(versionText);
      if (!cellLabel) {
        Logger.log(`Row ${row}: Could not normalize cell label from: "${versionText}"`);
        col += COLS_PER_VERSION;
        continue;
      }

      coveredLabels.add(cellLabel);

      Logger.log(`Row ${row}: Sheet col ${col} label="${cellLabel}" | CU dueDateMap has: ${JSON.stringify(dueDateMap)}`);

      // Update Due Date
      if (dueDateMap[cellLabel] !== undefined) {
        sheet.getRange(row, col + DUE_DATE_OFFSET).setValue(dueDateMap[cellLabel]);
        updated = true;
        Logger.log(`Row ${row}: ✅ Updated ${cellLabel} due date → ${dueDateMap[cellLabel]}`);
      } else {
        Logger.log(`Row ${row}: ⚠️ No due date in CU for label "${cellLabel}"`);
      }

      // Update Status
      if (statusMap[cellLabel] !== undefined) {
        sheet.getRange(row, col + STATUS_OFFSET).setValue(statusMap[cellLabel]);
        updated = true;
        Logger.log(`Row ${row}: ✅ Updated ${cellLabel} status → ${statusMap[cellLabel]}`);
      }

      col += COLS_PER_VERSION;
    }

    // --- NEW: Append extra subtasks that are NOT already in the sheet ---
    // Find first truly empty version slot after existing columns
    const allCuLabels = Object.keys(dueDateMap).concat(
      Object.keys(statusMap).filter(k => !dueDateMap[k])
    );
    const uniqueCuLabels = [...new Set(allCuLabels)];

    for (const label of uniqueCuLabels) {
      if (coveredLabels.has(label)) continue; // already handled above

      // Find next empty version column (where the Version cell is blank)
      let writeCol = VERSION_COL_START;
      while (writeCol <= lastCol) {
        const existing = String(sheet.getRange(row, writeCol).getValue()).trim();
        if (!existing) break; // found empty slot
        writeCol += COLS_PER_VERSION;
      }

      // Write the label, due date, and status
      sheet.getRange(row, writeCol).setValue(label);
      if (dueDateMap[label]) {
        sheet.getRange(row, writeCol + DUE_DATE_OFFSET).setValue(dueDateMap[label]);
      }
      if (statusMap[label]) {
        sheet.getRange(row, writeCol + STATUS_OFFSET).setValue(statusMap[label]);
      }
      updated = true;
      Logger.log(`Row ${row}: ➕ Appended extra subtask "${label}" at col ${writeCol}`);
    }

    if (updated) updatedRows++;

    // Respect API rate limits
    Utilities.sleep(200);
  }

  let message = `✅ Sync complete!\n\nRows updated: ${updatedRows}\n`;
  if (skippedRows.length > 0) {
    message += `\n⚠️ Skipped ${skippedRows.length} row(s) due to connection errors: rows ${skippedRows.join(', ')}\nRun sync again to retry those rows.`;
  }
  ui.alert(message);
