function extractTaskId(url) {
  if (!url) return null;
  const match = url.match(/clickup\.com\/t\/([a-zA-Z0-9]+)/);
  return match ? match[1] : null;
}

function formatDueDate(timestampMs) {
  if (!timestampMs) return '';
  const date = new Date(parseInt(timestampMs));
  return Utilities.formatDate(date, 'UTC', 'MMMM d');
}

function getTaskData(taskId, token) {
  const url = `https://api.clickup.com/api/v2/task/${taskId}?include_subtasks=true&subtasks=true`;
  const options = {
    method: 'GET',
    headers: { 'Authorization': token, 'Content-Type': 'application/json' },
    muteHttpExceptions: true
  };

  for (let attempt = 1; attempt <= 2; attempt++) {
    try {
      const response = UrlFetchApp.fetch(url, options);
      const code = response.getResponseCode();
      if (code === 200) return JSON.parse(response.getContentText());
      Logger.log(`Attempt ${attempt} — Error fetching task ${taskId}: HTTP ${code}`);
    } catch (e) {
      Logger.log(`Attempt ${attempt} — Connection error for task ${taskId}: ${e.message}`);
    }
    if (attempt === 1) Utilities.sleep(1000);
  }
  return null;
}

function parseVersionLabel(name) {
  if (!name) return null;
  const vMatch = name.match(/_V(\d+)/i);
  if (vMatch) return `V${vMatch[1]}`;
  const extras = ['Masters', 'Shoutout', 'Lyric', 'Lyrics', 'Square', 'Vertical', 'Horizontal'];
  for (const extra of extras) {
    if (name.match(new RegExp(extra, 'i'))) return extra.charAt(0).toUpperCase() + extra.slice(1).toLowerCase();
  }
  return null;
}

function normalizeCellLabel(cellText) {
  if (!cellText) return null;
  const text = String(cellText).trim();
  const vMatch = text.match(/^V(\d+)/i);
  if (vMatch) return `V${vMatch[1]}`;
  const extras = ['Masters', 'Shoutout', 'Lyric', 'Lyrics', 'Square', 'Vertical', 'Horizontal'];
  for (const extra of extras) {
    if (text.match(new RegExp(`^${extra}`, 'i'))) {
      return extra.charAt(0).toUpperCase() + extra.slice(1).toLowerCase();
    }
  }
  return null;
}

function normalizeStatus(statusName) {
  if (!statusName) return '';
  return statusName.toUpperCase();
}

function syncClickUp() {
  const token = getApiToken();
  if (!token) return;

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('VIP');
  if (!sheet) { SpreadsheetApp.getUi().alert('⚠️ Tab "VIP" not found.'); return; }

  const lastRow = sheet.getLastRow();
  const ui = SpreadsheetApp.getUi();
  let updatedRows = 0;
  let errorRows = 0;
  const skippedRows = [];

  for (let row = FIRST_DATA_ROW; row <= lastRow; row++) {
    const cell = sheet.getRange(row, COLUMN_CU_LINK);
    const richText = cell.getRichTextValue();
    let cuUrl = null;

    if (richText) {
      const runs = richText.getRuns();
      for (const run of runs) {
        const link = run.getLinkUrl();
        if (link && link.includes('clickup.com')) { cuUrl = link; break; }
      }
    }
    if (!cuUrl) {
      const val = cell.getValue();
      if (val && String(val).includes('clickup.com')) cuUrl = String(val);
    }
    if (!cuUrl) continue;

    const taskId = extractTaskId(cuUrl);
    if (!taskId) continue;

    const taskData = getTaskData(taskId, token);
    if (!taskData) { errorRows++; skippedRows.push(row); continue; }

    const mainStatus = normalizeStatus(taskData.status?.status);
    if (mainStatus) sheet.getRange(row, COLUMN_MAIN_STATUS).setValue(mainStatus);

    const subtasks = taskData.subtasks || [];
    const dueDateMap = {};
    const statusMap  = {};

    for (const subtask of subtasks) {
      const label = parseVersionLabel(subtask.name);
      if (!label) { Logger.log(`Row ${row}: Could not parse label from subtask name: "${subtask.name}"`); continue; }
      if (subtask.due_date) dueDateMap[label] = formatDueDate(subtask.due_date);
      if (subtask.status?.status) statusMap[label] = normalizeStatus(subtask.status.status);
      Logger.log(`Row ${row}: CU subtask parsed → label="${label}", due="${dueDateMap[label] || ''}", status="${statusMap[label] || ''}"`);
    }

    const lastCol = sheet.getLastColumn();
    let col = VERSION_COL_START;
    const coveredLabels = new Set();
    let updated = false;

    while (col <= lastCol) {
      const cellVal     = sheet.getRange(row, col).getValue();
      const versionText = String(cellVal).trim();
      if (!versionText) { col += COLS_PER_VERSION; continue; }

      const cellLabel = normalizeCellLabel(versionText);
      if (!cellLabel) { Logger.log(`Row ${row}: Could not normalize cell label from: "${versionText}"`); col += COLS_PER_VERSION; continue; }

      coveredLabels.add(cellLabel);
      Logger.log(`Row ${row}: Sheet col ${col} label="${cellLabel}" | CU dueDateMap has: ${JSON.stringify(dueDateMap)}`);

      if (dueDateMap[cellLabel] !== undefined) {
        sheet.getRange(row, col + DUE_DATE_OFFSET).setValue(dueDateMap[cellLabel]);
        updated = true;
        Logger.log(`Row ${row}: ✅ Updated ${cellLabel} due date → ${dueDateMap[cellLabel]}`);
      } else {
        Logger.log(`Row ${row}: ⚠️ No due date in CU for label "${cellLabel}"`);
      }

      if (statusMap[cellLabel] !== undefined) {
        sheet.getRange(row, col + STATUS_OFFSET).setValue(statusMap[cellLabel]);
        updated = true;
        Logger.log(`Row ${row}: ✅ Updated ${cellLabel} status → ${statusMap[cellLabel]}`);
      }

      col += COLS_PER_VERSION;
    }

    const allCuLabels    = Object.keys(dueDateMap).concat(Object.keys(statusMap).filter(k => !dueDateMap[k]));
    const uniqueCuLabels = [...new Set(allCuLabels)];

    for (const label of uniqueCuLabels) {
      if (coveredLabels.has(label)) continue;
      let writeCol = VERSION_COL_START;
      while (writeCol <= lastCol) {
        const existing = String(sheet.getRange(row, writeCol).getValue()).trim();
        if (!existing) break;
        writeCol += COLS_PER_VERSION;
      }
      sheet.getRange(row, writeCol).setValue(label);
      if (dueDateMap[label]) sheet.getRange(row, writeCol + DUE_DATE_OFFSET).setValue(dueDateMap[label]);
      if (statusMap[label])  sheet.getRange(row, writeCol + STATUS_OFFSET).setValue(statusMap[label]);
      updated = true;
      Logger.log(`Row ${row}: ➕ Appended extra subtask "${label}" at col ${writeCol}`);
    }

    if (updated) updatedRows++;
    Utilities.sleep(200);
  }

  let message = `✅ Sync complete!\n\nRows updated: ${updatedRows}\n`;
  if (skippedRows.length > 0) {
    message += `\n⚠️ Skipped ${skippedRows.length} row(s) due to connection errors: rows ${skippedRows.join(', ')}\nRun sync again to retry those rows.`;
  }
  ui.alert(message);
}

