function cleanProjectName(rawName) {
  if (!rawName) return '';
  return String(rawName).replace(/^VIP\d+_/i, '').trim();
}

function isActiveRow(sheet, row) {
  let col = VERSION_COL_START;
  const lastCol = sheet.getLastColumn();
  while (col <= lastCol) {
    const versionLabel = String(sheet.getRange(row, col).getValue()).trim();
    if (!versionLabel) { col += COLS_PER_VERSION; continue; }
    const vStatus = String(sheet.getRange(row, col + STATUS_OFFSET).getValue()).trim().toUpperCase();
    if (ACTIVE_STATUSES.includes(vStatus)) return true;
    col += COLS_PER_VERSION;
  }
  return false;
}

