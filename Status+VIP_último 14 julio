// POLLING — backup every 5 minutes
// ------------------------------------------------------------
function registrarTrigger() {
  const triggers = ScriptApp.getProjectTriggers();
  for (const t of triggers) {
    if (t.getHandlerFunction() === "syncStatuses") {
      ScriptApp.deleteTrigger(t);
    }
  }
  ScriptApp.newTrigger("syncStatuses")
    .timeBased()
    .everyMinutes(5)
    .create();
  Logger.log("✅ Trigger registrado — syncStatuses cada 5 minutos.");
}

function syncStatuses() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const taskMap = {};

  for (const tabName of SHEET_TABS) {
    const sheet = ss.getSheetByName(tabName);
    if (!sheet) continue;

    const lastRow = sheet.getLastRow();
    if (lastRow < 2) continue;

    const richValues   = sheet.getRange(2, COL_LINK, lastRow - 1, 1).getRichTextValues();
    const statusValues = sheet.getRange(2, COL_STATUS, lastRow - 1, 1).getValues();

    for (let i = 0; i < richValues.length; i++) {
      const url = extractUrl(richValues[i][0]);
      if (!url) continue;
      const taskId = extractUrlTaskId(url);
      if (!taskId) continue;
      taskMap[taskId] = { tabName, row: i + 2, currentStatus: statusValues[i][0] || "" };
    }
  }

  const totalTasks = Object.keys(taskMap).length;
  if (totalTasks === 0) { Logger.log("No tasks found in any tab."); return; }
  Logger.log("Tasks found in spreadsheet: " + totalTasks);

  const cuStatusMap = fetchAllTaskStatuses();
  if (!cuStatusMap) { Logger.log("ERROR: Could not fetch tasks from ClickUp."); return; }
  Logger.log("Tasks fetched from ClickUp: " + Object.keys(cuStatusMap).length);

  let updatedCount = 0;

  for (const [taskId, sheetData] of Object.entries(taskMap)) {
    const cuData = cuStatusMap[taskId];
    if (!cuData) continue;

    let newStatus = mapStatus(cuData.status);
    const hasResizeTag = cuData.tags.some(tag =>
      tag.name?.toLowerCase() === TAG_RESIZES.toLowerCase()
    );
    if (hasResizeTag && newStatus === "WORKING") newStatus = "RE-SIZES";
    if (!newStatus) continue;
    if (newStatus === sheetData.currentStatus) continue;

    const sheet = ss.getSheetByName(sheetData.tabName);
    if (!sheet) continue;

    sheet.getRange(sheetData.row, COL_STATUS).setValue(newStatus);
    Logger.log("[" + sheetData.tabName + "] Row " + sheetData.row + ": " + sheetData.currentStatus + " → " + newStatus);

    if (newStatus === "SENT") {
      const now = Utilities.formatDate(new Date(), TIMEZONE, "dd/MM/yyyy");
      sheet.getRange(sheetData.row, COL_DATE).setValue(now);
      Logger.log("[" + sheetData.tabName + "] SENT date → " + now);
    }

    updatedCount++;
  }

  Logger.log("Sync complete — updated: " + updatedCount + " / " + totalTasks + " tasks checked.");
}

function fetchAllTaskStatuses() {
  const cuMap = {};
  let page = 0;
  const maxPages = 500;

  while (page < maxPages) {
    const url = "https://api.clickup.com/api/v2/list/" + CLICKUP_LIST_ID +
      "/task?page=" + page + "&include_subtasks=false&subtasks=false";

    try {
      const response = UrlFetchApp.fetch(url, {
        method: "GET",
        headers: { Authorization: CLICKUP_API_KEY },
        muteHttpExceptions: true,
      });

      if (response.getResponseCode() !== 200) {
        Logger.log("CU API error on page " + page + ": HTTP " + response.getResponseCode());
        break;
      }

      const data  = JSON.parse(response.getContentText());
      const tasks = data.tasks || [];

      for (const task of tasks) {
        cuMap[task.id] = { status: task.status?.status || "", tags: task.tags || [] };
      }

      if (tasks.length < 100) break;
      page++;
      Utilities.sleep(200);

    } catch (e) {
      Logger.log("Error fetching page " + page + ": " + e);
      break;
    }
  }

  return cuMap;
}

function jsonResponse(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}


// ------------------------------------------------------------
// HELPERS — Part 1
// ------------------------------------------------------------
function extractUrl(richTextCell) {
  try {
    const runs = richTextCell.getRuns();
    for (const run of runs) {
      const link = run.getLinkUrl();
      if (link) return link;
    }
    const plainText = richTextCell.getText();
    if (plainText && plainText.startsWith("http")) return plainText;
  } catch (e) {}
  return null;
}

function extractUrlTaskId(url) {
  try {
    const cleanUrl = url.split("?")[0];
    const longMatch = cleanUrl.match(/clickup\.com\/t\/\d+\/([a-zA-Z0-9]+)/);
    if (longMatch) return longMatch[1];
    const shortMatch = cleanUrl.match(/clickup\.com\/t\/([a-zA-Z0-9]+)/);
    if (shortMatch) return shortMatch[1];
    const segments = cleanUrl.split("/").filter(Boolean);
    return segments[segments.length - 1];
  } catch (e) {}
  return null;
}

function mapStatus(rawStatus) {
  if (!rawStatus) return null;
  const map = {
    "submitted":       "SUBMITTED",
    "on hold":         "ON HOLD",
    "working":         "WORKING",
    "quality control": "QUALITY CONTROL",
    "qc approved":     "QC APPROVED",
    "sent":            "SENT",
    "completadas":     "COMPLETADAS",
    "complete":        "COMPLETE",
    "cancelled":       "CANCELLED",
    "subtitling":      "SUBTITLING",
    "re-sizes":        "RE-SIZES",
  };
  return map[rawStatus.toLowerCase()] || rawStatus.toUpperCase();
}


